# Server
PORT=3000

# Redis
REDIS_URL=redis://localhost:6379

# Kong Gateway (for proxying to real Nasiko agents)
KONG_GATEWAY_URL=http://localhost:9100

# Nasiko Backend API
NASIKO_BACKEND_URL=http://localhost:8000/api/v1

# Cache Defaults
CACHE_DEFAULT_TTL=300

# Rate Limiter Defaults
RATE_LIMIT_MAX_TOKENS=10
RATE_LIMIT_REFILL_RATE=2
RATE_LIMIT_MAX_QUEUE_SIZE=20
RATE_LIMIT_MAX_WAIT_TIME=30000

# Dashboard Origin (for CORS)
DASHBOARD_URL=http://localhost:5173
