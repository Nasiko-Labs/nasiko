# Nasiko Local Development Configuration
# This file contains environment variables for local bootstrap deployment

# Database Configuration
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=your-secure-mongo-password
MONGO_AUTH_DB=nasiko
MONGO_CHAT_DB=nasiko

# Security Configuration (CHANGE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
USER_CREDENTIALS_ENCRYPTION_KEY=your-base64-encoded-encryption-key

# Registry Configuration (using Docker Hub images)
NASIKO_REGISTRY_URL=nasiko
NASIKO_VERSION=latest

# Port Configuration (adjust if needed)
NASIKO_PORT_MONGODB=27017
NASIKO_PORT_REDIS=6379
NASIKO_PORT_KONG=9100
NASIKO_PORT_KONG_ADMIN=9101
NASIKO_PORT_KONG_MANAGER=9102
NASIKO_PORT_BACKEND=8000
NASIKO_PORT_WEB=4000
NASIKO_PORT_AUTH=8082
NASIKO_PORT_ROUTER=8081
NASIKO_PORT_CHAT=8083
NASIKO_PORT_SERVICE_REGISTRY=8080
NASIKO_PORT_KONGA=1337
NASIKO_PORT_PHOENIX=6006
NASIKO_PORT_PHOENIX_GRPC=4317
NASIKO_PORT_PHOENIX_HTTP=4318

# Application Configuration
AUTH_MODE=simple
K8S_ENABLED=false

# Docker Network Configuration
AGENTS_NETWORK=agents-net
APP_NETWORK=app-network
DOCKER_NETWORK=agents-net

# Superuser Configuration (Default admin account)
SUPERUSER_EMAIL=superuser-email
SUPERUSER_USERNAME=superuser-username
SUPERUSER_PASSWORD=superuser-password

# ---------------------------------------------------------------------------
# LLM Gateway (Track 2) — platform-managed LiteLLM proxy
#
# WARNING: Do NOT hardcode provider API keys in agent source, Dockerfiles,
# or agent-level .env files. The platform injects a gateway URL + virtual
# key into every agent container. Agents should read LITELLM_BASE_URL and
# LITELLM_VIRTUAL_KEY (or OPENAI_BASE_URL / OPENAI_API_KEY aliases) and
# call the gateway — the gateway holds the real provider credentials.
# ---------------------------------------------------------------------------
LITELLM_ENABLED=true
LITELLM_BASE_URL=http://litellm:4000
LITELLM_MASTER_KEY=sk-nasiko-master-dev
LITELLM_SALT_KEY=sk-nasiko-salt-dev
LITELLM_VIRTUAL_KEY=sk-nasiko-master-dev
LITELLM_DEFAULT_MODEL=gpt-4o-mini
NASIKO_PORT_LITELLM=4100

# Upstream provider keys — these live ONLY in the gateway, never in agents.
GROQ_API_KEY=gsk-your-groq-api-key

# Legacy: direct-provider keys. Kept so pre-Track-2 agents still boot. New
# agents should not depend on these.
OPENAI_API_KEY=sk-your-openai-api-key
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key
MINIMAX_API_KEY=your-minimax-api-key

# Router LLM Provider Configuration
# Supported values: "openai" (default), "openrouter", "minimax"
# ROUTER_LLM_PROVIDER=openai
# ROUTER_LLM_MODEL=gpt-4o-mini
# For MiniMax: ROUTER_LLM_PROVIDER=minimax, ROUTER_LLM_MODEL=MiniMax-M2.7

# Kong Database
KONG_DB_NAME=kong
KONG_DB_USER=kong
KONG_DB_PASSWORD=your-kong-db-password

# Phoenix Observability
PHOENIX_BASE_URL=http://phoenix-observability:6006
PHOENIX_GRPC_ENDPOINT=http://phoenix-observability:4317
PHOENIX_HTTP_ENDPOINT=http://phoenix-observability:4318